# Public site origin, no trailing slash (canonical URLs, Open Graph, sitemap)
VITE_SITE_URL=https://www.verystays.com

# Vercel Blob — create store in team Storage, connect to project, then redeploy.
# Required for community vote totals (see README).
BLOB_READ_WRITE_TOKEN=

# Pexels — optional, for scripts/fetch-station-images.mjs when Wikimedia has no photo.
# Get a key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: only needed for scripts/map-cp-stations.mjs (departures use /api/departures + server-side CP config).
# Refresh locally: node scripts/refresh-cp-env.mjs
VITE_CP_TRAVEL_API_URL=https://api-gateway.cp.pt/cp/services/travel-api
VITE_CP_API_KEY=
VITE_CP_CONNECT_ID=
VITE_CP_CONNECT_SECRET=
