# Public site origin, no trailing slash (canonical URLs, Open Graph, sitemap)
VITE_SITE_URL=https://www.verystays.com

# PostHog — project API key (Project Settings → Project API key)
# Anonymous visitors get a stable person profile via identify() (see src/lib/posthogIdentity.ts).
VITE_POSTHOG_TOKEN=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat Web Billing — public SDK key for @revenuecat/purchases-js (NOT mobile keys).
# Dashboard → Project → API keys → Web Billing app:
#   rcb_sb_…  sandbox (OK in production builds — use for preview/staging iteration)
#   rcb_…     production Web Billing
#   test_…    Test Store — local dev only (npm run dev); soft-skipped in prod builds
# Do NOT use mobile appl_/goog_/test_ keys from mobile/constants/revenueCat.ts here.
# Leave blank to disable RevenueCat (safe deploy — no crash, no blank screen). No paywall UI yet.
VITE_REVENUECAT_WEB_API_KEY=

# Vercel Blob — create store in team Storage, connect to project, then redeploy.
# Required for community vote totals (see README).
BLOB_READ_WRITE_TOKEN=

# Pexels — required on Vercel for automatic photo refresh at build time. https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: max stations to refresh per deploy (default 5).
# IMAGE_REFRESH_MAX_PER_BUILD=5

# AviationStack — primary source for scripts/collect-airport-connections.mjs
AVIATIONSTACK_API_KEY=
# AirLabs Schedules — fallback when AviationStack monthly quota is exhausted (~1000 req/mo free)
AIRLABS_API_KEY=

# Optional: only needed for scripts/map-cp-stations.mjs (departures use /api/departures + server-side CP config).
# Refresh locally: node scripts/refresh-cp-env.mjs
VITE_CP_TRAVEL_API_URL=https://api-gateway.cp.pt/cp/services/travel-api
VITE_CP_API_KEY=
VITE_CP_CONNECT_ID=
VITE_CP_CONNECT_SECRET=
