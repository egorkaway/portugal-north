{
  "expo": {
    "name": "VeryStays",
    "slug": "verystays",
    "version": "1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "verystays",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "buildNumber": "29",
      "bundleIdentifier": "com.iberian.travel",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true,
        "NSSupportsLiveActivitiesFrequentUpdates": true,
        "UIRequiresFullScreen": true,
        "NSLocationWhenInUseUsageDescription": "VeryStays uses your location to show the nearest train station on the home-screen widget when you have no upcoming trip."
      }
    },
    "android": {
      "package": "com.iberian.travel",
      "adaptiveIcon": {
        "backgroundColor": "#012841",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#012841"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "VeryStays uses your location to show the nearest train station on the home-screen widget when you have no upcoming trip."
        }
      ],
      "expo-notifications",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.iberian.travel.widgets",
          "groupIdentifier": "group.com.iberian.travel",
          "enablePushNotifications": false,
          "widgets": [
            {
              "name": "TripWidget",
              "displayName": "Train countdown",
              "description": "Countdown to your next train, last trip taken, or nearest station.",
              "ios": {
                "contentMarginsDisabled": true,
                "supportedFamilies": [
                  "systemSmall",
                  "systemMedium",
                  "accessoryRectangular",
                  "accessoryInline"
                ]
              }
            }
          ]
        }
      ],
      "./plugins/withWidgetContainerBackground.js",
      "expo-sharing",
      "expo-core-spotlight",
      "expo-localization",
      "./plugins/withAppIntents.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
