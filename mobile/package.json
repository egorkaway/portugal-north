{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~57.0.4",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-location": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "expo-widgets": "~57.0.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios --configuration Release",
    "ios:debug": "expo run:ios --configuration Debug",
    "ios:release": "expo run:ios --configuration Release --no-bundler",
    "ios:release:device": "expo run:ios --configuration Release --device",
    "ios:archive": "xcodebuild -workspace ios/VeryStays.xcworkspace -scheme VeryStays -configuration Release -destination 'generic/platform=iOS' -archivePath ios/build/VeryStays.xcarchive archive",
    "ios:pods": "cd ios && pod install",
    "ios:open": "open ios/VeryStays.xcworkspace",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "sync:data": "node --import tsx ./scripts/sync-data.mjs",
    "sync:icons": "node ./scripts/sync-icons.mjs"
  },
  "private": true
}
